# ============== 配置 ==============
DATA_FILE = Path(__file__).parent.parent / "data.json"
AGENT_API_CONFIG_FILE = Path(__file__).parent.parent / "agent_api_configs.json"

def load_agent_api_configs():
    """加载代理API配置"""
    try:
        with open(AGENT_API_CONFIG_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    except FileNotFoundError:
        return {}

_agent_api_configs = load_agent_api_configs()

def get_agent_api_config(agent_id: str) -> dict:
    """获取代理的实际API配置"""
    from main import app_settings, MINIMAX_BASE_URL, MINIMAX_API_KEY
    
    config = _agent_api_configs.get(agent_id, {})
    if config.get("use_global", True):
        # 使用全局配置
        return {
            "api_url": app_settings.get("apiUrl") or MINIMAX_BASE_URL,
            "api_key": app_settings.get("apiKey") or MINIMAX_API_KEY,
            "model": app_settings.get("model") or "MiniMax-M2.5"
        }
    else:
        # 使用代理专属配置
        return {
            "api_url": config.get("api_url") or app_settings.get("apiUrl") or MINIMAX_BASE_URL,
            "api_key": config.get("api_key") or app_settings.get("apiKey") or MINIMAX_API_KEY,
            "model": config.get("model") or app_settings.get("model") or "MiniMax-M2.5"
        }

# ============== 枚举定义 ==============

class AgentStatus(Enum):
    """代理状态"""
    IDLE = "idle"           # 空闲
    RUNNING = "running"     # 运行中
    PAUSED = "paused"       # 已暂停
    ERROR = "error"         # 错误
    STOPPED = "stopped"     # 已停止

class AgentRole(Enum):
    """代理角色"""
    WORKER = "worker"       # 执行器 - 执行具体任务
    PLANNER = "planner"     # 规划器 - 分解复杂任务
    REVIEWER = "reviewer"   # 审查器 - 检查结果质量
    COORDINATOR = "coordinator"  # 协调器 - 管理多代理协作
    CODER = "coder"         # 编程代理 - 编写代码
    RESEARCHER = "researcher"  # 研究代理 - 搜索分析
    WRITER = "writer"       # 写作代理 - 生成文档

class TaskStatus(Enum):
    """任务状态"""
    PENDING = "pending"
    QUEUED = "queued"
    RUNNING = "running"
    COMPLETED = "completed"
    FAILED = "failed"
    CANCELLED = "cancelled"

class TaskPriority(Enum):
    """任务优先级"""
    LOW = 1
    NORMAL = 5
    HIGH = 10
    CRITICAL = 20
    URGENT = 30

